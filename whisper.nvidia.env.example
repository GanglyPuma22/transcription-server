# Optional NVIDIA GPU runtime settings.
# Copy this file to whisper.env when using docker-compose.nvidia.yml.
#
# This variant is separate from the default CPU path because the upstream
# hwdsl2/whisper-server image currently validates cpu-only startup.
# The GPU compose override builds a local CUDA-capable image instead.

# Model to load. Start with base.en for a lighter first test, or switch to
# large-v3-turbo once the GPU path is confirmed working.
WHISPER_MODEL=base.en

# Default language hint.
WHISPER_LANGUAGE=en

# Port exposed inside the container.
WHISPER_PORT=9000

# Optional GPU mode.
WHISPER_DEVICE=cuda

# Good first choice for NVIDIA GPUs. For tighter VRAM, try int8_float16.
WHISPER_COMPUTE_TYPE=float16

# CPU threads still matter for preprocessing / host-side work.
WHISPER_THREADS=4
WHISPER_BEAM=5

# Protect the endpoint in any non-local setup.
WHISPER_API_KEY=CHANGE_ME_GENERATE_ON_DEPLOY
