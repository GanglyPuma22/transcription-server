# Whisper server runtime settings.
# Copy this file to whisper.env and fill in real values where needed.
#
# This file is NOT the same thing as .env.
# - whisper.env is read by the Whisper server container itself.
# - .env is used by Docker Compose on the host for deployment-specific values
#   like bind address, host port, and cache volume name.
#
# In short:
# - .env decides how the service is wired up on the host
# - whisper.env decides how the transcription server behaves at runtime

# Whisper model to load at startup.
WHISPER_MODEL=base.en

# Language hint used by the server.
WHISPER_LANGUAGE=en

# Port exposed by the server inside the container.
WHISPER_PORT=9000

# Inference device and compute settings.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Runtime tuning knobs.
WHISPER_THREADS=4
WHISPER_BEAM=5

# Bearer token used to protect the transcription endpoint.
# Replace this in your real whisper.env.
WHISPER_API_KEY=CHANGE_ME_GENERATE_ON_DEPLOY
