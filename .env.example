# Docker Compose host-side overrides.
# Copy this file to .env for machine-specific deployment settings.
#
# This file is NOT the same thing as whisper.env.
# - .env controls Docker Compose behavior on the host, such as bind address,
#   exposed port, and the Docker volume name used for the model cache.
# - whisper.env controls the runtime settings consumed by the Whisper server
#   inside the container, such as model, language, compute type, and API key.
#
# You usually want both files:
# - .env for host/network/deploy overrides
# - whisper.env for the transcription service itself

# Safer public default: bind only to localhost.
WHISPER_BIND_ADDR=127.0.0.1

# Host port exposed by Docker.
WHISPER_HOST_PORT=9000

# Docker volume name used for the Whisper model cache.
WHISPER_MODEL_CACHE_VOLUME_NAME=transcription-server-whisper-data
